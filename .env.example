# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
# All vars marked NEXT_PUBLIC_* are exposed to the browser.
# All others are server-only.

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side only, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Claude API (Anthropic) ─────────────────────────────────────────────────
# Server-side only. Never prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI Moderation API ─────────────────────────────────────────────────
# Used in /api/moderate-name for student name safety check (onboarding).
OPENAI_API_KEY=sk-...

# ── SendGrid ──────────────────────────────────────────────────────────────
# Used by the weekly-digest Supabase edge function.
# Also set these in Supabase dashboard → Edge Functions → Secrets.
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Weekly digest triggers ────────────────────────────────────────────────
# WEEKLY_DIGEST_SECRET: protects manual POST trigger
WEEKLY_DIGEST_SECRET=change-me-to-a-random-string
# CRON_SECRET: set in Vercel dashboard; Vercel injects this into cron GET requests
CRON_SECRET=change-me-to-another-random-string
